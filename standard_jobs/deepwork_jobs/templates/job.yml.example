# Example: Competitive Research Job
#
# This is a complete example of a job.yml file for reference.

name: competitive_research
summary: "Systematic competitive analysis workflow"

step_arguments:
  - name: market_segment
    description: "The market segment to analyze"
    type: string

  - name: product_category
    description: "The product category"
    type: string

  - name: competitors_list.md
    description: "Vetted list of direct and indirect competitors"
    type: file_path

  - name: research_notes.md
    description: "Detailed research notes on each competitor"
    type: file_path
    review:
      strategy: individual
      instructions: |
        Evaluate the output against these criteria:
        - Sufficient Data: Each competitor has at least 3 data points.
        - Sources Cited: Sources are cited for key claims.
        - Current Information: Information is current (within last year).

  - name: comparison_matrix.md
    description: "Side-by-side comparison matrix of all competitors"
    type: file_path

  - name: positioning_report.md
    description: "Strategic positioning recommendations"
    type: file_path
    review:
      strategy: individual
      instructions: |
        Read the comparison_matrix.md file to verify that recommendations
        are grounded in the competitive analysis data.

        Evaluate the output against these criteria:
        - Actionable: Recommendations are specific and actionable.
        - Data-Backed: Recommendations are supported by the competitive analysis data.

workflows:
  full_analysis:
    summary: "Complete competitive research from identification to positioning"
    common_job_info_provided_to_all_steps_at_runtime: |
      A comprehensive workflow for analyzing competitors in your market segment.
      Helps product teams understand the competitive landscape through systematic
      identification, research, comparison, and positioning recommendations.
    steps:
      - name: identify_competitors
        instructions: |
          Identify 5-7 key competitors in the target market segment.
          Use web search, industry reports, and analyst coverage to build
          a comprehensive list of direct and indirect competitors.

          For each competitor, document:
          - Company name and website
          - Brief description of their product/service
          - Why they are a competitor (direct vs indirect)
        inputs:
          market_segment:
            required: true
          product_category:
            required: true
        outputs:
          competitors_list.md:
            required: true

      - name: research_competitors
        instructions: |
          Deep dive research on each identified competitor.
          Analyze their website, product pages, pricing, and public materials.
          Document findings in a structured format.
        inputs:
          competitors_list.md:
            required: true
        outputs:
          research_notes.md:
            required: true
        process_requirements:
          "Consistent Style": "All research notes MUST follow the same structure."

      - name: comparative_analysis
        instructions: |
          Create a side-by-side comparison matrix of all competitors.
          Compare across key dimensions: features, pricing, target market,
          strengths, and weaknesses.
        inputs:
          research_notes.md:
            required: true
        outputs:
          comparison_matrix.md:
            required: true

      - name: positioning_recommendations
        instructions: |
          Based on the competitive analysis, develop strategic positioning
          recommendations. Identify market gaps, differentiation opportunities,
          and suggested positioning strategies.
        inputs:
          comparison_matrix.md:
            required: true
        outputs:
          positioning_report.md:
            required: true
